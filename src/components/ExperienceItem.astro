---
interface Props {
  company: string;
  title: string;
  date: string;
  description: string[];
  skills?: string[];
  color?: 'blue' | 'green' | 'yellow' | 'purple' | 'default';
}

const {
  company,
  title,
  date,
  description,
  skills = [],
  color = 'default',
} = Astro.props;

const colorMap = {
  blue: {
    dot: 'bg-blue-500',
    text: 'text-blue-400',
    border: 'border-blue-400/30',
  },
  green: {
    dot: 'bg-emerald-500',
    text: 'text-emerald-400',
    border: 'border-emerald-400/30',
  },
  yellow: {
    dot: 'bg-amber-500',
    text: 'text-amber-400',
    border: 'border-amber-400/30',
  },
  purple: {
    dot: 'bg-purple-500',
    text: 'text-purple-400',
    border: 'border-purple-400/30',
  },
  default: {
    dot: 'bg-primary-500',
    text: 'text-primary-400',
    border: 'border-primary-400/30',
  },
};

const theme = colorMap[color] || colorMap.default;
---

<div class="relative pl-8 md:pl-10 pb-12 group last:pb-0 gsap-experience-item">
  {/* The Timeline Dot */}
  <div
    class={`absolute size-2.5 rounded-full -left-1.5 top-1.5 ring-6 ring-surface-50 dark:ring-surface-950 ring-background ${theme.dot}`}
  >
  </div>

  {/* Header: Date and Badge (Company) */}
  <div class="flex flex-wrap items-center gap-3 mb-2">
    <span class="text-sm text-muted-foreground text-gray-400 font-medium"
      >{date}</span
    >
    <span
      class={`font-bebas tracking-wider leading-none text-md font-semibold px-2 pt-1.5 pb-0.5 rounded border uppercase ${theme.text} ${theme.border}`}
    >
      {company}
    </span>
  </div>

  {/* Job Title */}
  <h3 class="text-xl md:text-2xl font-bold text-foreground mb-3">{title}</h3>

  {/* Description */}
  <div class="flex flex-col gap-2 text-muted-foreground mb-4">
    {description.map((item) => <p class="text-base leading-relaxed">{item}</p>)}
  </div>

  {/* Skills */}
  {
    skills && skills.length > 0 && (
      <div class="mb-4">
        <h4 class="text-sm font-medium text-muted-foreground text-gray-400 mb-3">
          Skills:
        </h4>
        <div class="flex flex-wrap gap-2">
          {skills.map((skill) => (
            <span class="text-xs text-muted-foreground bg-zinc-800/30 border border-zinc-700/50 px-3 pt-1.5 pb-0.5 rounded-md hover:bg-zinc-800/80 transition-colors">
              {skill}
            </span>
          ))}
        </div>
      </div>
    )
  }

  <div
    class="mt-4 pt-6 border-b border-gray-500/40 group-last:border-none group-last:pt-0 group-last:mt-0"
  >
  </div>
</div>
