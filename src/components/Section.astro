---
interface Props {
  title: string;
  className?: string;
}

const { title, className = '' } = Astro.props;
---

<section
  class={`py-12 border-b border-gray-500/40 border-border last:border-0 ${className} gsap-section`}
>
  <div class="container mx-auto px-6 max-w-4xl">
    <h2
      class="text-3xl font-bold text-foreground mb-8 flex items-center gap-4 font-bebas tracking-wider"
    >
      <span class="w-8 h-1 bg-primary-500 rounded-full"></span>
      {title}
    </h2>
    <div class="space-y-8">
      <slot />
    </div>
  </div>
</section>
